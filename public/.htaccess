# sufis-berlin.de — Astro static deploy
# URLs are preserved 1:1 from the old WordPress site, so only canonicalisation
# + legacy WordPress cleanup is needed.

Options -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS + www (canonical host)
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.sufis-berlin.de%{REQUEST_URI} [L,R=301]

  # Kill legacy WordPress endpoints (feeds, xmlrpc, wp-admin, author archives)
  RewriteRule ^(.*/)?feed/?$ https://www.sufis-berlin.de/$1 [L,R=301]
  RewriteRule ^xmlrpc\.php$ - [G]
  RewriteRule ^wp-(login|admin|json|content|includes)(/|$) - [G]
  RewriteRule ^author/ https://www.sufis-berlin.de/ [L,R=301]
</IfModule>

# Trailing-slash directories are produced by Astro (build format: directory)

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  <FilesMatch "\.(?:css|js|woff2?|jpg|jpeg|png|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

ErrorDocument 404 /404.html
