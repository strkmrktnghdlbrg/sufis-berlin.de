---
const { id = 'lg' } = Astro.props;
---
<svg class="mark" viewBox="0 0 32 32" fill="none" aria-hidden="true">
  <rect x="1" y="1" width="30" height="30" rx="8" stroke={`url(#${id})`} stroke-width="2"/>
  <path d="M11 21c0-4 3-5 5-5s5 1 5 4-2.8 4-5 4M16 16c0-3.6 1.4-5.4 5-6M11 11c1.5 1 3 1.4 5 1.4" stroke={`url(#${id})`} stroke-width="2" stroke-linecap="round"/>
  <defs><linearGradient id={id} x1="0" y1="0" x2="32" y2="32"><stop stop-color="#8b5cf6"/><stop offset="1" stop-color="#ff2d7e"/></linearGradient></defs>
</svg>
