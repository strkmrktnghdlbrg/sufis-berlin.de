---
import BaseLayout from './BaseLayout.astro';

interface Crumb { href?: string; label: string; }
interface RelatedEntry { id: string; data: { title: string; excerpt?: string; cover?: { src: string; alt?: string } } }
interface Props {
  title: string;
  description?: string;
  metaTitle?: string;
  cover?: { src: string; alt?: string; credit?: string };
  publishDate?: string;
  updated?: string;
  breadcrumbs?: Crumb[];
  verifiedNote?: string;
  isGuestPost?: boolean;
  relatedEntries?: RelatedEntry[];
  relatedLabel?: string;
}
const { title, description, metaTitle, cover, publishDate, updated, breadcrumbs = [], verifiedNote, isGuestPost, relatedEntries = [], relatedLabel = 'Das könnte dich auch interessieren' } = Astro.props;
const fmt = (d?: string) => {
  if (!d) return '';
  const dt = new Date(d);
  return isNaN(+dt) ? '' : dt.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' });
};
---
<BaseLayout title={metaTitle || title} description={description} image={cover?.src}>
  <article class="article-hero">
    <div class="wrap">
      <div class="article-head">
        {breadcrumbs.length > 0 && (
          <nav class="breadcrumb" aria-label="Brotkrumen">
            {breadcrumbs.map((c, i) => (
              <>
                {c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
                {i < breadcrumbs.length - 1 && <span>›</span>}
              </>
            ))}
          </nav>
        )}
        <h1>{title}</h1>
        <div class="article-meta">
          {updated ? <span>Aktualisiert: {fmt(updated)}</span> : publishDate && <span>{fmt(publishDate)}</span>}
          <span>· SUFIS Berlin Redaktion</span>
        </div>
      </div>
      {cover?.src && (
        <figure class="article-cover">
          <img src={cover.src} alt={cover.alt || title} loading="eager" width="1200" height="630" />
          {cover.credit && <figcaption style="font-family:var(--font-ui);font-size:12px;color:var(--steel);padding:8px 14px;background:var(--wash)" set:html={cover.credit}></figcaption>}
        </figure>
      )}
    </div>
  </article>

  <div class="article">
    <div class="wrap">
      {isGuestPost && (
        <p class="guest-note">Dieser Beitrag wurde von einem externen Partner bereitgestellt.</p>
      )}
      <div class="prose">
        <slot />
      </div>
    </div>
  </div>

  {relatedEntries.length > 0 && (
    <section class="block cities" style="padding-top:56px;padding-bottom:72px">
      <div class="wrap">
        <div class="head">
          <span class="eyebrow">Mehr entdecken</span>
          <h2>{relatedLabel}</h2>
        </div>
        <div class="grid-3">
          {relatedEntries.map((e) => (
            <a class="acard" href={`/berlin/${e.id}/`}>
              {e.data.cover?.src && <img src={e.data.cover.src} alt={e.data.cover.alt || e.data.title} loading="lazy" width="600" height="178" />}
              <div class="body">
                <h3>{e.data.title}</h3>
                {e.data.excerpt && <p class="mt">{e.data.excerpt}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
