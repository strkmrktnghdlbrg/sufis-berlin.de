---
import BaseLayout from './BaseLayout.astro';

interface Crumb { href?: string; label: string; }
interface Props {
  title: string;
  description?: string;
  metaTitle?: string;
  cover?: { src: string; alt?: string; credit?: string };
  publishDate?: string;
  updated?: string;
  breadcrumbs?: Crumb[];
  verifiedNote?: string;
  isGuestPost?: boolean;
}
const { title, description, metaTitle, cover, publishDate, updated, breadcrumbs = [], verifiedNote, isGuestPost } = Astro.props;
const fmt = (d?: string) => {
  if (!d) return '';
  const dt = new Date(d);
  return isNaN(+dt) ? '' : dt.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' });
};
---
<BaseLayout title={metaTitle || title} description={description} image={cover?.src}>
  <article class="article-hero">
    <div class="wrap">
      <div class="article-head">
        {breadcrumbs.length > 0 && (
          <nav class="breadcrumb" aria-label="Brotkrumen">
            {breadcrumbs.map((c, i) => (
              <>
                {c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
                {i < breadcrumbs.length - 1 && <span>›</span>}
              </>
            ))}
          </nav>
        )}
        <h1>{title}</h1>
        <div class="article-meta">
          {updated ? <span>Aktualisiert: {fmt(updated)}</span> : publishDate && <span>{fmt(publishDate)}</span>}
          <span>· SUFIS Berlin Redaktion</span>
        </div>
      </div>
      {cover?.src && (
        <figure class="article-cover">
          <img src={cover.src} alt={cover.alt || title} loading="eager" width="1200" height="630" />
          {cover.credit && <figcaption style="font-family:var(--font-ui);font-size:12px;color:var(--steel);padding:8px 14px;background:var(--wash)" set:html={cover.credit}></figcaption>}
        </figure>
      )}
    </div>
  </article>

  <div class="article">
    <div class="wrap">
      {isGuestPost && (
        <p class="guest-note">Dieser Beitrag wurde von einem externen Partner bereitgestellt.</p>
      )}
      <div class="prose">
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>
