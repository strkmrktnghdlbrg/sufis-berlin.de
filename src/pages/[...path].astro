---
// Guest posts & misc off-topic posts kept at their exact original WordPress path.
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('extra');
  return entries.map((entry) => ({ params: { path: entry.data.path }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
const parts = d.path.split('/');
const segment = parts[0];
const catName = segment.charAt(0).toUpperCase() + segment.slice(1);
const breadcrumbs = parts.length > 1
  ? [{ href: '/', label: 'Start' }, { label: catName }, { label: d.title }]
  : [{ href: '/', label: 'Start' }, { label: d.title }];
---
<ArticleLayout
  title={d.title}
  metaTitle={d.metaTitle || `${d.title} – SUFIS Berlin`}
  description={d.metaDescription}
  cover={d.cover}
  publishDate={d.publishDate}
  updated={d.updated}
  breadcrumbs={breadcrumbs}
  isGuestPost={d.isGuestPost}
  alternateUrls={{ de: `/${d.path}/` }}
>
  <Content />
</ArticleLayout>
