---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { GENRES, BEZIRKE } from '../../data/site';

export async function getStaticPaths() {
  const entries = await getCollection('berlin');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const kindLabel: Record<string, string> = { genre: 'Genres', bezirk: 'Bezirke', special: 'Nachtleben', guide: 'Magazin' };
const kindHref: Record<string, string> = { genre: '/genres/', bezirk: '/bezirke/', special: '/berlin/die-besten-nachtclubs/', guide: '/magazin/' };
const breadcrumbs = [
  { href: '/', label: 'Start' },
  { href: kindHref[d.kind] ?? '/magazin/', label: kindLabel[d.kind] ?? 'Magazin' },
  { label: d.title },
];

// Plan[0]: collect same-kind siblings (excluding current page), cap at 4
const allBerlin = await getCollection('berlin');
const siblings = allBerlin
  .filter((e) => e.id !== entry.id && e.data.kind === d.kind)
  .slice(0, 4);

const relatedLabelMap: Record<string, string> = {
  genre: 'Weitere Genres entdecken',
  bezirk: 'Weitere Berliner Bezirke',
  special: 'Mehr aus dem Nachtleben',
  guide: 'Das könnte dich auch interessieren',
};

// Plan[3]: for bezirk pages, fetch matching hotel pages
let bezirkHotels: { id: string; data: { title: string; excerpt: string; cover?: { src: string; alt?: string } } }[] = [];
if (d.kind === 'bezirk') {
  // Derive bezirk name from slug: "nachtclubs-in-friedrichshain" → "Friedrichshain"
  // We match by comparing hotel bezirk field (e.g. "Friedrichshain") against the bezirk list name
  const bezirkEntry = BEZIRKE.find((b) => b.slug === entry.id);
  if (bezirkEntry) {
    const allHotels = await getCollection('hotels');
    bezirkHotels = allHotels
      .filter((h) => h.data.bezirk?.toLowerCase() === bezirkEntry.name.toLowerCase())
      .slice(0, 2)
      .map((h) => ({ id: h.id, data: { title: h.data.title, excerpt: h.data.excerpt, cover: h.data.cover } }));
  }
}
---
<ArticleLayout
  title={d.title}
  metaTitle={d.metaTitle || `${d.title} – SUFIS Berlin`}
  description={d.metaDescription}
  cover={d.cover}
  publishDate={d.publishDate}
  updated={d.updated}
  breadcrumbs={breadcrumbs}
  verifiedNote={d.verifiedNote}
  relatedEntries={siblings}
  relatedLabel={relatedLabelMap[d.kind] ?? 'Das könnte dich auch interessieren'}
>
  <Content />

  {/* Plan[2]: genre pages get a "Clubs nach Bezirk" pill bar */}
  {d.kind === 'genre' && (
    <div style="margin-top:48px;padding-top:40px;border-top:1px solid var(--mist)">
      <p style="font-family:var(--font-ui);font-size:13px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--neon);margin-bottom:14px">Clubs nach Bezirk</p>
      <div class="pillwrap">
        {BEZIRKE.map((b) => (
          <a class="pill" href={`/berlin/${b.slug}/`}>{b.name}</a>
        ))}
      </div>
    </div>
  )}

  {/* Plan[2]: bezirk pages get a "Clubs nach Sound" pill bar */}
  {d.kind === 'bezirk' && (
    <div style="margin-top:48px;padding-top:40px;border-top:1px solid var(--mist)">
      <p style="font-family:var(--font-ui);font-size:13px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--neon);margin-bottom:14px">Clubs nach Sound</p>
      <div class="pillwrap">
        {GENRES.map((g) => (
          <a class="pill" href={`/berlin/${g.slug}/`}>{g.name}</a>
        ))}
      </div>
    </div>
  )}

  {/* Plan[3]: bezirk pages get a hotel teaser block */}
  {d.kind === 'bezirk' && bezirkHotels.length > 0 && (
    <div style="margin-top:48px;padding-top:40px;border-top:1px solid var(--mist)">
      <p style="font-family:var(--font-ui);font-size:13px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--neon);margin-bottom:14px">Hotels in der Naehe</p>
      <div class="grid-2" style="max-width:46rem">
        {bezirkHotels.map((h) => (
          <a class="acard" href={`/hotels/${h.id}/`}>
            {h.data.cover?.src && <img src={h.data.cover.src} alt={h.data.cover.alt || h.data.title} loading="lazy" width="600" height="178" />}
            <div class="body">
              <h3>{h.data.title}</h3>
              {h.data.excerpt && <p class="mt" style="font-size:13px;color:var(--steel)">{h.data.excerpt}</p>}
            </div>
          </a>
        ))}
      </div>
      <a class="morelink" href="/hotels/" style="margin-top:20px">Alle Hotels ansehen &rarr;</a>
    </div>
  )}
</ArticleLayout>
