---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../../data/site';

const hotels = (await getCollection('hotelsEn')).sort((a, b) => a.data.title.localeCompare(b.data.title));
---
<BaseLayout
  title="Hotels in Berlin - by Neighborhood & Style - SUFIS Berlin"
  description="Boutique, design and charming hotels across every Berlin neighborhood - the perfect base for your night out. Compare live prices on the booking map."
  locale="en"
  alternateUrls={{ de: '/hotels/', en: '/en/hotels/' }}
>
  <section class="block">
    <div class="wrap">
      <div class="head">
        <span class="eyebrow">Where to stay in Berlin</span>
        <h2>Hotels by neighborhood & style</h2>
        <p>From a boutique hotel in Mitte to a design hotel in Friedrichshain - find the right place to stay for your Berlin night. Book directly on the live map below.</p>
      </div>
      <div class="grid-3">
        {hotels.map((h) => (
          <a class="vcard" href={`/en/hotels/${h.id}/`}>
            <h3>{h.data.title}</h3>
            <p>{h.data.excerpt || h.data.metaDescription}</p>
            <div class="cnt">View hotels →</div>
          </a>
        ))}
      </div>
      {SITE.stay22LmaId && (
        <div style="margin-top:40px;border:1px solid var(--fog);border-radius:var(--r-img);overflow:hidden">
          <iframe title="Hotels in Berlin" style="width:100%;height:500px;border:0" loading="lazy"
            src={`https://www.stay22.com/embed/gm?aid=${SITE.stay22LmaId}&lat=52.52&lng=13.405&maincolor=ff2d7e&markername=Berlin`}></iframe>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
