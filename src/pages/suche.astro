---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const berlin = await getCollection('berlin');
const hotels = await getCollection('hotels');
const idx = [
  ...berlin.map((e) => ({ t: e.data.title, d: e.data.excerpt || e.data.metaDescription, u: `/berlin/${e.id}/`, k: e.data.kind })),
  ...hotels.map((e) => ({ t: e.data.title, d: e.data.excerpt || e.data.metaDescription, u: `/hotels/${e.id}/`, k: 'hotel' })),
];
---
<BaseLayout title="Suche – SUFIS Berlin" description="Durchsuche Berlins Clubs, Bars, Genres und Bezirke." noindex={true}>
  <section class="block">
    <div class="wrap" style="max-width:820px">
      <div class="head"><span class="eyebrow">Suche</span><h2>Finde deine Nacht</h2></div>
      <div class="field" style="margin-bottom:24px"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg><div class="stack"><input id="q" placeholder="z. B. Techno, Friedrichshain, Berghain, Dresscode" autofocus /></div></div>
      <div id="results" class="grid-2"></div>
      <p id="empty" class="muted" style="display:none">Keine Treffer. Versuch ein anderes Stichwort.</p>
    </div>
  </section>
  <script define:vars={{ idx }}>
    const q = document.getElementById('q');
    const out = document.getElementById('results');
    const empty = document.getElementById('empty');
    const render = (list) => {
      out.innerHTML = list.map((r) => `<a class="vcard" href="${r.u}"><h3>${r.t}</h3><p>${r.d || ''}</p></a>`).join('');
      empty.style.display = list.length ? 'none' : 'block';
    };
    const search = (term) => {
      term = term.trim().toLowerCase();
      if (!term) { out.innerHTML = ''; empty.style.display = 'none'; return; }
      render(idx.filter((r) => (r.t + ' ' + (r.d || '') + ' ' + r.k).toLowerCase().includes(term)).slice(0, 30));
    };
    const params = new URLSearchParams(location.search);
    const initial = params.get('q') || params.get('bezirk') || '';
    if (initial) { q.value = initial; search(initial); }
    q.addEventListener('input', (e) => search(e.target.value));
  </script>
</BaseLayout>
